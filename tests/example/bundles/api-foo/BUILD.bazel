# The ``api-foo`` bundle: a small, self-contained RST tree, generated
# by genrules. Outputs land at ``bazel-bin/bundles/api-foo/`` — exactly
# where the host project's ``ubproject.toml`` mounts them from
# (``../bazel-bin/bundles/api-foo``, relative to the TOML's directory).
#
# A real project would generate these files with proper rules — from
# code comments, from a service description, from a database — rather
# than hard-coded ``cat`` commands. The shape (genrule producing files
# under a Bazel package) is what matters.

genrule(
    name = "gen_index",
    outs = ["index.rst"],
    cmd = """cat > $@ <<'EOF'
api-foo
=======

API_FOO_INDEX_MARKER

This is the entry document of the api-foo bundle, generated by Bazel
and mounted in place by ``sphinx-mounts``.

.. toctree::
   :maxdepth: 1

   reference
   coverage
EOF
""",
)

genrule(
    name = "gen_reference",
    outs = ["reference.rst"],
    cmd = """cat > $@ <<'EOF'
Reference
---------

API_FOO_REFERENCE_MARKER

Reference page of the api-foo bundle. The host project never names
this file by hand — the toctree above (inside the bundle) handles
intra-bundle navigation, and the host wires the bundle's
``index`` doc into its own toctree via ``attach_to``.
EOF
""",
)

# A bundle page that references a pre-built HTML coverage report. The
# report is shipped as a static artefact (see //coverage_report) and
# placed into the site output by the host's ``html_extra_path``; this
# page just links to and embeds it. The link/iframe target is relative
# to this page's output location (``_generated/api-foo/coverage.html``),
# so ``../../coverage/index.html`` reaches the report at the site root.
genrule(
    name = "gen_coverage",
    outs = ["coverage.rst"],
    cmd = """cat > $@ <<'EOF'
Coverage report
----------------

API_FOO_COVERAGE_MARKER

This page links to and embeds a **pre-built HTML coverage report** that
ships alongside the bundle. The report is *not* parsed or copied by the
mount: the host project's ``html_extra_path`` places it verbatim in the
site output (at ``coverage/``) so the built docs stay self-contained, and
this page simply links to and embeds it. A plain link/iframe records no
Sphinx file dependency, so nothing is read or duplicated at parse time.

.. raw:: html

   <p><a href="../../coverage/index.html" target="_blank" rel="noopener">
   Open the full coverage report</a></p>
   <iframe src="../../coverage/index.html" title="Coverage report"
           width="100%" height="360" style="border:1px solid #ccc"></iframe>
EOF
""",
)

filegroup(
    name = "bundle",
    srcs = [
        ":gen_coverage",
        ":gen_index",
        ":gen_reference",
    ],
    visibility = ["//visibility:public"],
)
