# The ``api-foo`` bundle: a small, self-contained RST tree, generated
# by genrules. Outputs land at ``bazel-bin/bundles/api-foo/`` — exactly
# where the host project's ``ubproject.toml`` mounts them from
# (``../bazel-bin/bundles/api-foo``, relative to the TOML's directory).
#
# A real project would generate these files with proper rules — from
# code comments, from a service description, from a database — rather
# than hard-coded ``cat`` commands. The shape (genrule producing files
# under a Bazel package) is what matters.

genrule(
    name = "gen_index",
    outs = ["index.rst"],
    cmd = """cat > $@ <<'EOF'
api-foo
=======

API_FOO_INDEX_MARKER

This is the entry document of the api-foo bundle, generated by Bazel
and mounted in place by ``sphinx-mounts``.

.. toctree::
   :maxdepth: 1

   reference
EOF
""",
)

genrule(
    name = "gen_reference",
    outs = ["reference.rst"],
    cmd = """cat > $@ <<'EOF'
Reference
---------

API_FOO_REFERENCE_MARKER

Reference page of the api-foo bundle. The host project never names
this file by hand — the toctree above (inside the bundle) handles
intra-bundle navigation, and the host wires the bundle's
``index`` doc into its own toctree via ``attach_to``.
EOF
""",
)

filegroup(
    name = "bundle",
    srcs = [
        ":gen_index",
        ":gen_reference",
    ],
    visibility = ["//visibility:public"],
)
